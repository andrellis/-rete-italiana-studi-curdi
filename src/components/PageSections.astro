---
const { sections = [] } = Astro.props;

const enabledSections = Array.isArray(sections)
  ? sections.filter((section) => section && section.enabled !== false)
  : [];

const widthMap = {
  sm: 'max-w-3xl',
  md: 'max-w-4xl',
  lg: 'max-w-5xl',
};
---

{enabledSections.map((section) => {
  const anchorId = section.anchor ? section.anchor : undefined;

  if (section.type === 'hero') {
    const title = section.title || '';
    const subtitle = section.subtitle || '';
    const overlayOpacity = typeof section.overlayOpacity === 'number' ? section.overlayOpacity : 60;
    const overlayStyle = `background: linear-gradient(0deg, rgba(0,0,0,${overlayOpacity / 100}) 0%, rgba(0,0,0,${overlayOpacity / 100}) 100%)`;
    return (
      <section id={anchorId} class="relative overflow-hidden">
        {section.backgroundImage && (
          <img
            src={section.backgroundImage}
            alt=""
            class="absolute inset-0 h-full w-full object-cover"
            loading="lazy"
          />
        )}
        <div class="absolute inset-0" style={overlayStyle}></div>
        <div class="relative mx-auto max-w-5xl px-6 py-20 text-white">
          {title && <h1 class="text-4xl md:text-5xl font-bold mb-4">{title}</h1>}
          {subtitle && <p class="text-lg md:text-xl text-white/90 max-w-3xl">{subtitle}</p>}
          <div class="mt-8 flex flex-wrap gap-3">
            {section.ctaButton1Label && section.ctaButton1Url && (
              <a class="inline-flex items-center rounded-full bg-white text-gray-900 px-6 py-3 font-semibold hover:bg-gray-100 transition" href={section.ctaButton1Url}>
                {section.ctaButton1Label}
              </a>
            )}
            {section.ctaButton2Label && section.ctaButton2Url && (
              <a class="inline-flex items-center rounded-full border border-white/70 text-white px-6 py-3 font-semibold hover:bg-white/10 transition" href={section.ctaButton2Url}>
                {section.ctaButton2Label}
              </a>
            )}
          </div>
        </div>
      </section>
    );
  }

  if (section.type === 'banner') {
    const theme = section.theme || 'light';
    const themeClass =
      theme === 'dark'
        ? 'bg-gray-900 text-white'
        : theme === 'accent'
          ? 'bg-red-600 text-white'
          : 'bg-gray-50 text-gray-900';
    return (
      <section id={anchorId} class={`py-12 ${themeClass}`}>
        <div class="mx-auto max-w-5xl px-6 grid gap-8 md:grid-cols-2 md:items-center">
          <div>
            {section.title && <h2 class="text-3xl font-bold mb-3">{section.title}</h2>}
            {section.text && <p class="text-lg opacity-90">{section.text}</p>}
            {section.buttonLabel && section.buttonUrl && (
              <a class="mt-6 inline-flex items-center rounded-full bg-white/90 text-gray-900 px-6 py-3 font-semibold hover:bg-white transition" href={section.buttonUrl}>
                {section.buttonLabel}
              </a>
            )}
          </div>
          {section.image && (
            <div class="rounded-2xl overflow-hidden shadow-lg">
              <img src={section.image} alt={section.title || ''} class="w-full h-full object-cover" loading="lazy" />
            </div>
          )}
        </div>
      </section>
    );
  }

  if (section.type === 'text') {
    const align = section.align === 'center' ? 'text-center' : 'text-left';
    const maxWidth = widthMap[section.maxWidth as keyof typeof widthMap] || 'max-w-4xl';
    return (
      <section id={anchorId} class="py-12">
        <div class={`mx-auto px-6 ${maxWidth}`}>
          {section.title && <h2 class={`text-3xl font-bold mb-4 ${align}`}>{section.title}</h2>}
          {section.body && (
            <div class={`prose prose-lg max-w-none ${align === 'text-center' ? 'mx-auto' : ''}`}>
              <div>{section.body}</div>
            </div>
          )}
        </div>
      </section>
    );
  }

  if (section.type === 'image') {
    const fullWidth = section.fullWidth === true;
    return (
      <section id={anchorId} class="py-12">
        <div class={fullWidth ? 'px-0' : 'mx-auto max-w-5xl px-6'}>
          {section.image && (
            <img src={section.image} alt={section.caption || ''} class="w-full rounded-2xl shadow-md" loading="lazy" />
          )}
          {section.caption && <p class="mt-3 text-sm text-gray-500">{section.caption}</p>}
        </div>
      </section>
    );
  }

  if (section.type === 'gallery') {
    return (
      <section id={anchorId} class="py-12">
        <div class="mx-auto max-w-6xl px-6">
          {section.title && <h2 class="text-3xl font-bold mb-6">{section.title}</h2>}
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {(section.images || []).map((imageItem: any) => (
              <div>
                <img src={imageItem.image} alt={imageItem.caption || ''} class="w-full rounded-xl shadow-sm" loading="lazy" />
                {imageItem.caption && <p class="mt-2 text-sm text-gray-500">{imageItem.caption}</p>}
              </div>
            ))}
          </div>
        </div>
      </section>
    );
  }

  if (section.type === 'icons') {
    return (
      <section id={anchorId} class="py-12 bg-gray-50">
        <div class="mx-auto max-w-6xl px-6">
          {section.title && <h2 class="text-3xl font-bold mb-8">{section.title}</h2>}
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {(section.items || []).map((item: any) => (
              <div class="bg-white rounded-2xl p-6 shadow-sm">
                {item.iconImage && <img src={item.iconImage} alt="" class="h-10 w-10 mb-4" loading="lazy" />}
                <h3 class="text-xl font-semibold mb-2">{item.title}</h3>
                {item.text && <p class="text-gray-600 mb-4">{item.text}</p>}
                {item.linkLabel && item.linkUrl && (
                  <a class="text-red-600 font-semibold hover:underline" href={item.linkUrl}>
                    {item.linkLabel}
                  </a>
                )}
              </div>
            ))}
          </div>
        </div>
      </section>
    );
  }

  if (section.type === 'cta') {
    const theme = section.theme || 'accent';
    const themeClass =
      theme === 'dark'
        ? 'bg-gray-900 text-white'
        : theme === 'light'
          ? 'bg-gray-100 text-gray-900'
          : 'bg-red-600 text-white';
    return (
      <section id={anchorId} class={`py-16 ${themeClass}`}>
        <div class="mx-auto max-w-4xl px-6 text-center">
          {section.title && <h2 class="text-3xl font-bold mb-4">{section.title}</h2>}
          {section.text && <p class="text-lg opacity-90 mb-6">{section.text}</p>}
          {section.buttonLabel && section.buttonUrl && (
            <a class="inline-flex items-center rounded-full bg-white text-gray-900 px-6 py-3 font-semibold hover:bg-gray-100 transition" href={section.buttonUrl}>
              {section.buttonLabel}
            </a>
          )}
        </div>
      </section>
    );
  }

  return null;
})}
