---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import PageHero from '../../components/PageHero.astro';
import Logo from '../../components/Logo.astro';

let homepageSettings: any[] = [];
try {
  homepageSettings = await getCollection('homepage-en');
} catch (error) {
  console.warn('Homepage EN collection not found or empty:', error);
}

const settings = homepageSettings.length > 0 ? homepageSettings[0]?.data : null;

const allArticles = await getCollection('articoli-en');
const allPublications = await getCollection('pubblicazioni-en');
const allEvents = await getCollection('eventi-en');
const allNews = await getCollection('news-en');

const articlesCount = settings?.featuredArticlesCount || 3;
const publicationsCount = settings?.featuredPublicationsCount || 3;
const eventsCount = settings?.featuredEventsCount || 3;
const newsCount = settings?.featuredNewsCount || 3;
const updatesCount = settings?.updatesCount || 6;

const featuredArticles = allArticles
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, articlesCount);

const featuredPublications = allPublications
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, publicationsCount);

const upcomingEvents = allEvents
  .filter(event => event.data.eventDate >= new Date())
  .sort((a, b) => a.data.eventDate.getTime() - b.data.eventDate.getTime())
  .slice(0, eventsCount);

const latestNews = allNews
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, newsCount);

const articlesTitle = settings?.articlesSectionTitle || 'Recent Articles';
const publicationsTitle = settings?.publicationsSectionTitle || 'Recent Publications';
const eventsTitle = settings?.eventsSectionTitle || 'Upcoming Events';
const newsTitle = settings?.newsSectionTitle || 'News';
const updatesTitle = settings?.updatesSectionTitle || 'Recent Updates';
const joinTitle = settings?.joinTitle || 'How to Join';
const joinContent = settings?.joinContent || 'To join the mailing list and participate in events, please send us your CV and a brief introductory message.';
const joinEmail = settings?.joinEmail || 'rete.italiana.studi.curdi@gmail.com';

const defaultOrder = [
  { type: 'hero', enabled: true },
  { type: 'brand', enabled: true },
  { type: 'updates', enabled: true },
  { type: 'about', enabled: settings?.showAboutSection !== false },
  { type: 'join', enabled: true },
];

const sectionsOrder: Array<Record<string, any>> = Array.isArray(settings?.sections) && settings.sections.length > 0
  ? settings.sections
  : defaultOrder;

const toWordExcerpt = (text: string, maxWords = 50) => {
  if (!text) return '';
  const words = text.replace(/\s+/g, ' ').trim().split(' ');
  if (words.length <= maxWords) return words.join(' ');
  return `${words.slice(0, maxWords).join(' ')}…`;
};
---
<Layout lang="en" title="Italian Network of Kurdish Studies - Home" description="The Italian Network of Kurdish Studies promotes research and knowledge about Kurdish society and culture.">
  {sectionsOrder.map((s: any) => {
    if (s?.enabled === false) return null;
    switch (s?.type) {
      case 'hero':
        return (
          <PageHero 
            title={s?.title || settings?.heroTitle || 'Italian Network of Kurdish Studies'}
            subtitle={s?.subtitle || settings?.heroSubtitle || 'A network of scholars, researchers, and students devoted to Kurdish studies. We promote rigorous academic exchange and collaboration.'}
            backgroundImage={s?.heroBackgroundImage || settings?.heroBackgroundImage}
            overlayOpacity={s?.heroOverlayOpacity ?? settings?.heroOverlayOpacity ?? 60}
            showButtons={true}
            ctaButton1Label={s?.ctaButton1Label ?? settings?.ctaButton1Label}
            ctaButton1Url={s?.ctaButton1Url ?? settings?.ctaButton1Url}
            ctaButton2Label={s?.ctaButton2Label ?? settings?.ctaButton2Label}
            ctaButton2Url={s?.ctaButton2Url ?? settings?.ctaButton2Url}
          />
        );
      case 'brand':
        return (
          <section class="py-10 bg-white">
            <div class={`max-w-${s?.maxWidth === 'sm' ? '3xl' : s?.maxWidth === 'lg' ? '7xl' : '5xl'} mx-auto px-4 sm:px-6 lg:px-8`}>
              <div class={`flex ${s?.align === 'left' ? 'justify-start' : s?.align === 'right' ? 'justify-end' : 'justify-center'}`}>
                <Logo 
                  variant={s?.logoVariant || 'full'}
                  size="lg"
                  showLogoImage={s?.showLogoImage !== false}
                  showLogoText={s?.showLogoText !== false}
                  siteName={settings?.heroTitle || 'Italian Network of Kurdish Studies'}
                />
              </div>
            </div>
          </section>
        );
      case 'updates':
        const updates = [
          ...allNews.map((item) => ({
            type: 'News',
            date: item.data.pubDate,
            title: item.data.title,
            description: toWordExcerpt(item.data.description || item.body, 50),
            heroImage: item.data.heroImage,
            url: `/en/news/${item.slug}`,
            featured: !!item.data.featured,
          })),
          ...allEvents.map((item) => ({
            type: 'Event',
            date: item.data.eventDate,
            title: item.data.title,
            description: toWordExcerpt(item.data.description || item.body, 50),
            heroImage: item.data.heroImage,
            url: `/en/events/${item.slug}`,
            featured: !!item.data.featured,
          })),
          ...allArticles.map((item) => ({
            type: 'Article',
            date: item.data.pubDate,
            title: item.data.title,
            description: toWordExcerpt(item.data.description || item.body, 50),
            heroImage: item.data.heroImage,
            url: `/en/articles/${item.slug}`,
            featured: !!item.data.featured,
          })),
          ...allPublications.map((item) => ({
            type: 'Publication',
            date: item.data.pubDate,
            title: item.data.title,
            description: toWordExcerpt(item.data.abstract || item.body, 50),
            heroImage: item.data.heroImage,
            url: `/en/publications/${item.slug}`,
            featured: !!item.data.featured,
          })),
        ]
          .sort((a, b) => {
            if (a.featured !== b.featured) return a.featured ? -1 : 1;
            return b.date.getTime() - a.date.getTime();
          })
          .slice(0, updatesCount);

        return updates.length > 0 && (
          <section class="py-16 bg-gray-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
              <div class="flex items-center justify-between mb-8">
                <h2 class="text-3xl font-bold text-gray-900">{updatesTitle}</h2>
              </div>
              <div class="relative">
                <button type="button" class="updates-scroll-left absolute left-0 top-0 h-full w-10 flex items-center justify-center bg-white/80 hover:bg-white border-r border-gray-200 z-10 pointer-events-auto" aria-label="Scroll left">
                  ←
                </button>
                <button type="button" class="updates-scroll-right absolute right-0 top-0 h-full w-10 flex items-center justify-center bg-white/80 hover:bg-white border-l border-gray-200 z-10 pointer-events-auto" aria-label="Scroll right">
                  →
                </button>
                <div class="overflow-hidden pl-12 pr-12">
                  <div class="updates-scroll-track flex gap-6">
                    {[...updates, ...updates].map((item, idx) => (
                      <article class="min-w-[280px] max-w-[320px] bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow" data-idx={idx}>
                        {item.heroImage && (
                          <div class="w-full aspect-[16/9] bg-gray-50 overflow-hidden">
                            <img
                              src={item.heroImage}
                              alt={item.title}
                              class="w-full h-full object-contain"
                            />
                          </div>
                        )}
                        <div class="p-6">
                          <div class="inline-flex items-center mb-3">
                            <span class="text-xs font-semibold uppercase tracking-wide bg-red-100 text-red-700 px-3 py-1 rounded-full">
                              {item.type}
                            </span>
                          </div>
                          <h3 class="text-xl font-semibold text-gray-900 mb-2">
                            <a href={item.url} class="hover:text-red-600 transition-colors">
                              {item.title}
                            </a>
                          </h3>
                          <p class="text-gray-600 text-sm mb-4">{item.description}</p>
                          <a href={item.url} class="text-red-600 font-semibold text-sm hover:text-red-700">Read more →</a>
                          <div class="text-sm text-gray-500 mt-2">
                            {item.date.toLocaleDateString('en-GB')}
                          </div>
                        </div>
                      </article>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </section>
        );
      case 'news':
        return (latestNews.length > 0) && (
          <section class="py-16 bg-gray-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
              <div class="flex items-center justify-between mb-8">
                <h2 class="text-3xl font-bold text-gray-900">{newsTitle}</h2>
                <a href="/en/news" class="text-red-600 font-semibold hover:text-red-700">View all →</a>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {latestNews.map((item) => (
                  <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
                    {item.data.heroImage && (
                      <div class="w-full aspect-[16/9] bg-gray-50 overflow-hidden">
                        <img 
                          src={item.data.heroImage} 
                          alt={item.data.title}
                          class="w-full h-full object-contain"
                        />
                      </div>
                    )}
                    <div class="p-6">
                      <h3 class="text-xl font-semibold text-gray-900 mb-2">
                        <a href={`/en/news/${item.slug}`} class="hover:text-red-600 transition-colors">
                          {item.data.title}
                        </a>
                      </h3>
                      <p class="text-gray-600 text-sm mb-4">
                        {item.data.description || item.body.slice(0, 140) + '...'}
                      </p>
                      <div class="flex items-center justify-between text-sm text-gray-500">
                        <span>{item.data.pubDate.toLocaleDateString('en-GB')}</span>
                        {item.data.author && <span>by {item.data.author}</span>}
                      </div>
                    </div>
                  </article>
                ))}
              </div>
            </div>
          </section>
        );
      case 'articles':
        return (featuredArticles.length > 0) && (
          <section class="py-16 bg-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
              <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">{articlesTitle}</h2>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {featuredArticles.map((article) => (
                  <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
                    {article.data.heroImage && (
                      <img 
                        src={article.data.heroImage} 
                        alt={article.data.title}
                        class="w-full h-48 object-cover"
                      />
                    )}
                    <div class="p-6">
                      <h3 class="text-xl font-semibold text-gray-900 mb-2">
                        <a href={`/en/articles/${article.slug}`} class="hover:text-red-600 transition-colors">
                          {article.data.title}
                        </a>
                      </h3>
                      <p class="text-gray-600 text-sm mb-4">
                        {article.data.description || article.body.slice(0, 150) + '...'}
                      </p>
                      <div class="flex items-center justify-between text-sm text-gray-500">
                        <span>{article.data.pubDate.toLocaleDateString('en-GB')}</span>
                        {article.data.author && <span>by {article.data.author}</span>}
                      </div>
                    </div>
                  </article>
                ))}
              </div>
              <div class="text-center mt-8">
                <a href="/en/articles" class="bg-red-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-red-700 transition-colors">
                  View All Articles
                </a>
              </div>
            </div>
          </section>
        );
      case 'publications':
        return (featuredPublications.length > 0) && (
          <section class="py-16 bg-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
              <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">{publicationsTitle}</h2>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {featuredPublications.map((publication) => (
                  <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow border border-gray-200">
                    <div class="p-6">
                      <h3 class="text-xl font-semibold text-gray-900 mb-2">
                        <a href={`/en/publications/${publication.slug}`} class="hover:text-red-600 transition-colors">
                          {publication.data.title}
                        </a>
                      </h3>
                      <p class="text-gray-600 text-sm mb-3 font-medium">
                        {publication.data.authors.join(', ')}
                      </p>
                      <p class="text-gray-600 text-sm mb-4">
                        {publication.data.publisher} • {publication.data.pubDate.toLocaleDateString('en-GB')}
                      </p>
                      <p class="text-gray-600 text-sm mb-4 line-clamp-3">
                        {publication.data.abstract}
                      </p>
                      <div class="flex flex-wrap gap-2">
                        {publication.data.doi && (
                          <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded-full text-xs">
                            DOI
                          </span>
                        )}
                        {publication.data.tags && publication.data.tags.slice(0, 2).map((tag) => (
                          <span class="bg-gray-100 text-gray-700 px-2 py-1 rounded-full text-xs">
                            {tag}
                          </span>
                        ))}
                      </div>
                    </div>
                  </article>
                ))}
              </div>
              <div class="text-center mt-8">
                <a href="/en/publications" class="bg-red-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-red-700 transition-colors">
                  View All Publications
                </a>
              </div>
            </div>
          </section>
        );
      case 'events':
        return (upcomingEvents.length > 0) && (
          <section class="py-16 bg-gray-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
              <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">{eventsTitle}</h2>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {upcomingEvents.map((event) => (
                  <div class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow">
                    <h3 class="text-xl font-semibold text-gray-900 mb-2">
                      <a href={`/en/events/${event.slug}`} class="hover:text-red-600 transition-colors">
                        {event.data.title}
                      </a>
                    </h3>
                    <p class="text-gray-600 text-sm mb-4">
                      {event.data.description || event.body.slice(0, 150) + '...'}
                    </p>
                    <div class="text-sm text-gray-500 space-y-1">
                      <p>📅 {event.data.eventDate.toLocaleDateString('en-GB')}</p>
                      {event.data.location && <p>📍 {event.data.location}</p>}
                    </div>
                  </div>
                ))}
              </div>
              <div class="text-center mt-8">
                <a href="/en/events" class="bg-red-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-red-700 transition-colors">
                  View All Events
                </a>
              </div>
            </div>
          </section>
        );
      case 'about':
        return (settings?.showAboutSection !== false) && (
          <section class="py-16 bg-white">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
              <h2 class="text-3xl font-bold text-gray-900 mb-8">{settings?.aboutTitle || 'About Us'}</h2>
              <p class="text-lg text-gray-600 leading-relaxed mb-8">
                {settings?.aboutContent || 'The Italian Network of Kurdish Studies is a network of scholars, researchers, and students devoted to Kurdish studies. It promotes rigorous academic exchange, knowledge sharing, and collaboration.'}
              </p>
              <a href="/en/about" class="bg-red-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-red-700 transition-colors">
                Learn More
              </a>
            </div>
          </section>
        );
      case 'join':
        return (
          <section class="py-16 bg-white">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
              <h2 class="text-3xl font-bold text-gray-900 mb-8">{joinTitle}</h2>
              <p class="text-lg text-gray-600 leading-relaxed mb-6">{joinContent}</p>
              <a href={`mailto:${joinEmail}`} class="bg-red-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-red-700 transition-colors">
                {joinEmail}
              </a>
            </div>
          </section>
        );
    }
    return null;
  })}
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const track = document.querySelector('.updates-scroll-track');
    if (!track) return;
    const container = track.parentElement;
    if (!container) return;
    const leftBtn = document.querySelector('.updates-scroll-left');
    const rightBtn = document.querySelector('.updates-scroll-right');

    let autoScroll = false;
    let direction = 1;
    let rafId: number | null = null;

    const step = () => {
      if (!autoScroll) return;
      container.scrollLeft += 0.8 * direction;
      if (container.scrollLeft >= (track.scrollWidth / 2)) {
        container.scrollLeft = 0;
      }
      if (container.scrollLeft <= 0) {
        container.scrollLeft = track.scrollWidth / 2;
      }
      rafId = requestAnimationFrame(step);
    };

    const getStep = () => {
      const first = track.children[0];
      const second = track.children[1];
      if (first && second) {
        const firstRect = first.getBoundingClientRect();
        const secondRect = second.getBoundingClientRect();
        return Math.max(1, Math.round(secondRect.left - firstRect.left));
      }
      if (first) {
        return Math.max(1, Math.round(first.getBoundingClientRect().width));
      }
      return 320;
    };

    const start = () => {
      if (rafId) return;
      autoScroll = true;
      rafId = requestAnimationFrame(step);
    };
    const stop = () => {
      autoScroll = false;
      if (rafId) {
        cancelAnimationFrame(rafId);
        rafId = null;
      }
    };

    const startLeft = () => { direction = -1; start(); };
    const startRight = () => { direction = 1; start(); };

    leftBtn?.addEventListener('mouseenter', startLeft);
    leftBtn?.addEventListener('mouseleave', stop);
    rightBtn?.addEventListener('mouseenter', startRight);
    rightBtn?.addEventListener('mouseleave', stop);

    leftBtn?.addEventListener('touchstart', startLeft, { passive: true });
    leftBtn?.addEventListener('touchend', stop);
    leftBtn?.addEventListener('touchcancel', stop);
    rightBtn?.addEventListener('touchstart', startRight, { passive: true });
    rightBtn?.addEventListener('touchend', stop);
    rightBtn?.addEventListener('touchcancel', stop);

    leftBtn?.addEventListener('click', () => {
      const stepSize = getStep();
      container.scrollBy({ left: -stepSize, behavior: 'smooth' });
    });
    rightBtn?.addEventListener('click', () => {
      const stepSize = getStep();
      container.scrollBy({ left: stepSize, behavior: 'smooth' });
    });
  });
</script>
