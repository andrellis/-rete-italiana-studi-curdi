---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articoli-en');
const featuredArticles = allArticles.filter(article => article.data.featured);
const regularArticles = allArticles.filter(article => !article.data.featured);
---

<Layout lang="en" title="Articles - Italian Network of Kurdish Studies" description="Articles and publications on Kurdish studies">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Articles</h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Articles and publications from the Italian Network of Kurdish Studies
      </p>
    </div>

    {featuredArticles.length > 0 && (
      <section class="mb-16">
        <h2 class="text-2xl font-bold text-gray-900 mb-8">Featured</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {featuredArticles.map((article) => (
            <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
              {article.data.heroImage && (
                <img 
                  src={article.data.heroImage} 
                  alt={article.data.title}
                  class="w-full h-64 object-cover"
                />
              )}
              <div class="p-6">
                <h3 class="text-xl font-semibold text-gray-900 mb-2">
                  <a href={`/en/articles/${article.slug}`} class="hover:text-red-600 transition-colors">
                    {article.data.title}
                  </a>
                </h3>
                <p class="text-gray-600 mb-4">{article.data.description}</p>
                <div class="flex items-center justify-between text-sm text-gray-500">
                  <span>{article.data.pubDate.toLocaleDateString('en-GB')}</span>
                  {article.data.author && <span>by {article.data.author}</span>}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    <section>
      <h2 class="text-2xl font-bold text-gray-900 mb-8">All Articles</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {regularArticles.map((article) => (
          <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
            {article.data.heroImage && (
              <img 
                src={article.data.heroImage} 
                alt={article.data.title}
                class="w-full h-48 object-cover"
              />
            )}
            <div class="p-6">
              <h3 class="text-lg font-semibold text-gray-900 mb-2">
                <a href={`/en/articles/${article.slug}`} class="hover:text-red-600 transition-colors">
                  {article.data.title}
                </a>
              </h3>
              <p class="text-gray-600 text-sm mb-4">
                {article.data.description || article.body.slice(0, 120) + '...'}
              </p>
              <div class="flex items-center justify-between text-sm text-gray-500">
                <span>{article.data.pubDate.toLocaleDateString('en-GB')}</span>
                {article.data.author && <span>by {article.data.author}</span>}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>
  </div>
</Layout>
